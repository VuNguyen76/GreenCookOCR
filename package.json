{
  "name": "greencook-ocr",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "overrides": {
    "esbuild": "0.28.1"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,green \"tsx watch src/server/index.ts\" \"vite\"",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsup src/server/index.ts --format esm --out-dir dist-server --clean --sourcemap",
    "build:web": "vite build",
    "start": "node dist-server/index.js",
    "db:migrate": "tsx src/server/db/migrate.ts",
    "db:check": "tsx scripts/check-db.ts",
    "ocr:sample": "tsx scripts/ocr-sample.ts",
    "e2e:sample": "tsx scripts/e2e-upload.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "^10.1.0",
    "@google/genai": "^2.12.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^5.10.0",
    "fastify": "^5.10.0",
    "fflate": "^0.8.3",
    "file-type": "^22.0.1",
    "lucide-react": "^1.24.0",
    "mammoth": "^1.12.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
