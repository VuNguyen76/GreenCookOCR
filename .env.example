GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_API_VERSION=v1
GEMINI_MEDIA_RESOLUTION=medium
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_SSL=false
# Use TARGET_DATABASE_URL when the iDempiere target has different credentials.
# TARGET_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/sg
TARGET_DATABASE_NAME=sg
TARGET_AD_CLIENT_ID=11
TARGET_AD_ORG_ID=0
TARGET_AD_USER_ID=100
STAGING_DATABASE_PATH=./storage/greencook-ocr.sqlite
HOST=127.0.0.1
PORT=3000
UPLOAD_DIR=./storage/uploads
WORK_DIR=./storage/work
MAX_FILE_SIZE_MB=50
WORKER_POLL_MS=1200
MAX_ATTEMPTS=3
ANTIWORD_PATH=antiword
